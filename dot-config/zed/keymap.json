[
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "space f": "file_finder::Toggle",
      "space s": "project_symbols::Toggle",
      "g d a": "diagnostics::Deploy",
      "g d f": "diagnostics::DeployCurrentFile"
    }
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      ";": "command_palette::Toggle"
    }
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      ";": "command_palette::Toggle"
    }
  },
  {
    "context": "(!Editor && !Terminal)",
    "bindings": {
      ";": "command_palette::Toggle"
    }
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      ";": "command_palette::Toggle"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "space g": "pane::DeploySearch"
    }
  },
  {
    "context": "(!Editor && !Terminal)",
    "bindings": {
      "space g": "pane::DeploySearch"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "g o": "vim::GoToTab",
      "g u": "vim::GoToPreviousTab"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "space k": "workspace::ActivatePaneUp"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "space j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "space h": "workspace::ActivatePaneLeft"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "space l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Editor && vim_mode==normal && !menu",
    "bindings": {
      "space z": "workspace::ToggleZoom",
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "ctrl-w c": "pane::CloseActiveItem"
  }
},
  {
    "context": "Workspace",
    "bindings": {
      "space space": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Editor&&vim_mode==normal&&!menu",
    "bindings": {
      "\\": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "ProjectPanel&&not_editing",
    "bindings": {
      "\\": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "TabSwitcher",
    "bindings": {
      "d": "tab_switcher::CloseSelectedItem"
    }
  }
]
